@model DupdGrowth.Web.Models.DashboardDetailViewModel
@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["SidebarUserName"] = User.Identity?.Name ?? "Sample User";
    ViewData["ChartShowGrowthIndicator"] = false;
}
@section Styles {
    <link rel="stylesheet" href="~/css/User/UserDropped.css" asp-append-version="true" />
}
@await Html.PartialAsync("_DashboardDetailPageBody", Model)
@section Scripts {
    @await Html.PartialAsync("_DashboardPapDetailPageScripts")
}
