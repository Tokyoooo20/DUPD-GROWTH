@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["SidebarUserName"] = User.Identity?.Name ?? "Sample User";
    ViewData["ChartShowGrowthIndicator"] = false;
    ViewData["UserReportAddProgramShowQuarterStatus"] = false;
    ViewData["UserReportAddProgramCreateNewLayout"] = true;
}
@section Styles {
    <link rel="stylesheet" href="~/css/User/CreateNew.css" asp-append-version="true" />
}
<div class="app-shell d-flex">
    @await Html.PartialAsync("_CollapsibleUserSidebarShell")
    <div class="app-content d-flex flex-column flex-grow-1 min-w-0">
        @await Html.PartialAsync("Navbar")
        <main role="main" class="app-main flex-grow-1 bg-light">
            <div class="container-fluid dashboard-page dashboard-page--tight px-3 px-sm-4 px-lg-5 py-4">
                <header class="dashboard-page-header mb-3">
                    <h1 class="dashboard-page-title">Create new</h1>
                    <p class="text-body-secondary small mb-0">Enter the details for a new program or project.</p>
                </header>
                <div id="papTableCard" class="pap-table-card-wrap">
                    <form id="createNewPapForm"
                          class="dashboard-card__body p-3 p-md-4 bg-white"
                          method="post"
                          autocomplete="off">
                        @Html.AntiForgeryToken()
                        @await Html.PartialAsync("_UserReportAddProgramFormFields")
                        <div class="d-flex flex-wrap gap-2 justify-content-end border-top pt-3 mt-4">
                            <button type="button" class="btn btn-outline-secondary" id="createNewCancelBtn">Cancel</button>
                            <button type="button" class="btn btn-primary" id="userReportAddProgramSave">Save as Endorsed</button>
                        </div>
                    </form>
                </div>
            </div>
        </main>
    </div>
</div>
@{
    var createNewSaveEndorsedModal = new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
    {
        ["ModalId"] = "createNewSaveEndorsedConfirmModal",
        ["ModalTitle"] = "Save as endorsed?",
        ["ModalSize"] = "modal-sm",
        ["ModalBody"] = "<p class=\"mb-0\">Are you sure you want to save this project as endorsed?</p>",
        ["ModalPrimaryText"] = "Save as Endorsed",
        ["ModalPrimaryButtonId"] = "createNewSaveEndorsedConfirmBtn",
        ["ModalPrimaryDismiss"] = false,
        ["ModalSecondaryText"] = "Close",
    };
    var createNewCancelModal = new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
    {
        ["ModalId"] = "createNewCancelConfirmModal",
        ["ModalTitle"] = "Clear the form?",
        ["ModalSize"] = "modal-sm",
        ["ModalBody"] = "<p class=\"mb-0\">All text you entered will be removed from this page.</p>",
        ["ModalPrimaryText"] = "Clear",
        ["ModalPrimaryButtonId"] = "createNewCancelConfirmBtn",
        ["ModalPrimaryDismiss"] = false,
        ["ModalSecondaryText"] = "Stay",
    };
    var createNewPriorityDuplicateModal = new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
    {
        ["ModalId"] = "createNewPriorityDuplicateModal",
        ["ModalTitle"] = "Priority number already in use",
        ["ModalTitleHtml"] = "<span class=\"d-inline-flex align-items-center gap-2\"><i class=\"bi bi-exclamation-triangle-fill text-danger flex-shrink-0\" aria-hidden=\"true\"></i><span>Priority number already in use</span></span>",
        ["ModalSize"] = "modal-sm",
        ["ModalContentClass"] = "border-danger border-2 shadow-sm",
        ["ModalHeaderClass"] = "bg-white border-bottom border-danger",
        ["ModalTitleClass"] = "fw-semibold text-dark fs-6 mb-0",
        ["ModalCloseButtonClass"] = "btn-close",
        ["ModalPrimaryButtonClass"] = "btn btn-outline-danger",
        ["ModalBody"] = "<p class=\"mb-0 text-body\" id=\"createNewPriorityDuplicateModalMessage\">This priority number is already assigned to another project in your office. Please enter a different priority number.</p>",
        ["ModalPrimaryText"] = "OK",
        ["ModalPrimaryDismiss"] = true,
        ["ModalSecondaryText"] = "Close",
    };
}
@await Html.PartialAsync("Modal", null, createNewSaveEndorsedModal)
@await Html.PartialAsync("Modal", null, createNewCancelModal)
@await Html.PartialAsync("Modal", null, createNewPriorityDuplicateModal)
@section Scripts {
    @await Html.PartialAsync("_DashboardPapDetailPageScripts")
    @await Html.PartialAsync("_UserReportCreateNewFormScripts")
}
