@{
    var showYear = ViewData["NavbarShowYear"] as bool? == true;
    var selectedYear = ViewData["NavbarSelectedYear"] as int? ?? 2026;
    var years = ViewData["NavbarYears"] as IEnumerable<int> ?? new[] { 2026, 2025, 2024, 2023 };
    var segment = ViewData["NavbarSegment"] as string;
    var page = ViewData["NavbarPage"] as int?;
    var yearDetailAction = ViewData["NavbarYearDetailAction"] as string ?? "DashboardDetail";
    var navOfficeName = User.FindFirst("OfficeName")?.Value;
    var navParentOfficeName = User.FindFirst("ParentOfficeName")?.Value;
    var navShowParentOffice = !string.IsNullOrWhiteSpace(navParentOfficeName);
    var navShowOfficeStrip = User.Identity?.IsAuthenticated == true
        && (!string.IsNullOrWhiteSpace(navOfficeName) || navShowParentOffice);
}
<nav class="navbar navbar-expand-lg bg-white border-bottom flex-shrink-0 app-topbar">
    <div class="container-fluid d-flex flex-wrap align-items-center justify-content-between gap-2 gap-sm-3">
        @if (navShowOfficeStrip)
        {
            <div class="navbar-user navbar-user--capslock text-start small text-uppercase">
                @if (navShowParentOffice)
                {
                    <div class="navbar-user__line navbar-user__line--primary text-dark text-nowrap" title="Parent office">@navParentOfficeName</div>
                }
                @if (!string.IsNullOrWhiteSpace(navOfficeName))
                {
                    <div class="navbar-user__line navbar-user__line--primary text-dark text-nowrap" title="Your office">@navOfficeName</div>
                }
            </div>
        }
        @if (showYear)
        {
            <div class="dropdown @(!navShowOfficeStrip ? "ms-auto" : null)" id="navbarYearDropdown">
                <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" id="navbarYearButton">
                    Year: @selectedYear
                </button>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarYearButton">
                    @foreach (var y in years)
                    {
                        <li>
                            @if (string.IsNullOrEmpty(segment))
                            {
                                <a class="dropdown-item @(y == selectedYear ? "active" : null)"
                                   asp-controller="Dashboard"
                                   asp-action="Dashboard"
                                   asp-route-year="@y">@y</a>
                            }
                            else
                            {
                                <a class="dropdown-item @(y == selectedYear ? "active" : null)"
                                   asp-controller="Dashboard"
                                   asp-action="@yearDetailAction"
                                   asp-route-segment="@segment"
                                   asp-route-page="@(page ?? 1)"
                                   asp-route-year="@y">@y</a>
                            }
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
</nav>
