@model DupdGrowth.Web.Models.PagedUserListViewModel
<div class="dashboard-card__body p-0" data-users-results data-current-page="@Model.Page">
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th scope="col">Name</th>
                    <th scope="col">Office</th>
                    <th scope="col">Email</th>
                    <th scope="col">Status</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Items)
                {
                    <tr>
                        <td>@u.Name</td>
                        <td>@u.Office</td>
                        <td>@u.Email</td>
                        <td>
                            @if (u.IsApproved)
                            {
                                <span class="badge text-bg-success">Approved</span>
                            }
                            else
                            {
                                <span class="badge text-bg-warning text-dark">Pending approval</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="d-inline-flex flex-wrap gap-1 justify-content-end">
                                @if (!u.IsApproved)
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-outline-success"
                                            data-bs-toggle="modal"
                                            data-bs-target="#approveUserModal"
                                            data-user-approve-id="@u.Id"
                                            data-user-approve-name="@u.Name"
                                            data-page="@Model.Page"
                                            data-search="@Model.Search"
                                            data-office="@Model.Office">
                                        Approve
                                    </button>
                                }
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteUserModal"
                                        data-user-id="@u.Id"
                                        data-user-name="@u.Name"
                                        data-page="@Model.Page"
                                        data-search="@Model.Search"
                                        data-office="@Model.Office">
                                    Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.TotalPages > 1)
    {
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 px-3 py-3 border-top bg-white">

            <nav aria-label="User list pagination">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : null)">
                        <a class="page-link d-inline-flex align-items-center justify-content-center user-pagination-arrow" asp-controller="Users" asp-action="Users" asp-route-page="@(Model.Page - 1)" asp-route-search="@Model.Search" asp-route-office="@Model.Office" aria-label="Previous page">
                            <i class="bi bi-chevron-left" aria-hidden="true"></i>
                        </a>
                    </li>
                    @for (var p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : null)">
                            <a class="page-link" asp-controller="Users" asp-action="Users" asp-route-page="@p" asp-route-search="@Model.Search" asp-route-office="@Model.Office">@p</a>
                        </li>
                    }
                    <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : null)">
                        <a class="page-link d-inline-flex align-items-center justify-content-center user-pagination-arrow" asp-controller="Users" asp-action="Users" asp-route-page="@(Model.Page + 1)" asp-route-search="@Model.Search" asp-route-office="@Model.Office" aria-label="Next page">
                            <i class="bi bi-chevron-right" aria-hidden="true"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
