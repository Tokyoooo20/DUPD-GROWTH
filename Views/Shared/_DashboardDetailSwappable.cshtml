@model DupdGrowth.Web.Models.DashboardDetailViewModel
@{
    var papListAction = ViewData["PapListAction"] as string ?? "DashboardDetail";
    var papListController = ViewData["PapListController"] as string ?? "Dashboard";
    var detailBackController = ViewData["DetailBackController"] as string ?? "Dashboard";
    var detailBackAction = ViewData["DetailBackAction"] as string ?? "Dashboard";
    var detailBackIncludeYear = ViewData["DetailBackIncludeYear"] as bool? ?? true;
    var detailBackUrl = detailBackIncludeYear
        ? Url.Action(detailBackAction, detailBackController, new { year = Model.SelectedYear })!
        : Url.Action(detailBackAction, detailBackController)!;

    bool IsActive(string segment) =>
        Model.Kpi.ActiveSegment is not null &&
        string.Equals(Model.Kpi.ActiveSegment, segment, StringComparison.OrdinalIgnoreCase);

    var showKpiStrip = ViewData["DashboardDetailShowKpiStrip"] as bool? ?? true;
    var showGrowthFilter = ViewData["DashboardDetailShowGrowthFilter"] as bool? ?? true;
    var mainHeading = ViewData["DashboardDetailMainHeading"] as string;
    var showTableToolbar = ViewData["DashboardDetailShowTableToolbar"] as bool? ?? false;
    var papSearchListKey = ViewData["PapSearchListKey"] as string;
    var showPriorityNoColumn = ViewData["DashboardDetailShowPriorityNoColumn"] as bool? ?? showTableToolbar;
    var showRowDelete = ViewData["DashboardDetailShowRowDelete"] as bool? ?? false;
    var showRowEdit = ViewData["DashboardDetailShowRowEdit"] as bool? ?? true;
    var showRowActionsColumn = showRowEdit || showRowDelete;
    var rowActionsColumnHeading = ViewData["DashboardDetailRowActionsColumnHeading"] as string ?? "Actions";
    var completionPhotoUploadUrl = ViewData["ProjectCompletionPhotoUploadUrl"] as string;
    var completionPhotoViewOnly = ViewData["DashboardDetailCompletionPhotoViewOnly"] as bool? ?? false;
    var showCompletionPhotoUpload = ViewData["DashboardDetailShowCompletionPhotoUpload"] as bool? ?? false;
    var showCompletionPhotoColumn = showCompletionPhotoUpload && (!string.IsNullOrWhiteSpace(completionPhotoUploadUrl) || completionPhotoViewOnly);
}
<div id="dashboardDetailSwappable"
     class="dashboard-detail-swappable"
     data-selected-year="@Model.SelectedYear"
     data-detail-back-url="@detailBackUrl">
@if (showKpiStrip)
{
<div class="row g-3 g-lg-4 mb-3 mb-lg-4">
    <div class="col-6 col-xl-3">
        <a class="kpi-link kpi-link--partial h-100 d-block @(IsActive(DashboardSegments.Total) ? "kpi-link--active" : null)"
           asp-controller="@papListController"
           asp-action="@papListAction"
           asp-route-segment="@DashboardSegments.Total"
           asp-route-year="@Model.SelectedYear"
           asp-route-growth="@Model.GrowthFilter"
           aria-current="@(IsActive(DashboardSegments.Total) ? "page" : null)">
            <div class="h-100" data-kpi-total-paps data-value="@Model.Kpi.TotalPapsValue" data-label="Total PAPs"></div>
        </a>
    </div>
    <div class="col-6 col-xl-3">
        <a class="kpi-link kpi-link--partial h-100 d-block @(IsActive(DashboardSegments.Completed) ? "kpi-link--active" : null)"
           asp-controller="@papListController"
           asp-action="@papListAction"
           asp-route-segment="@DashboardSegments.Completed"
           asp-route-year="@Model.SelectedYear"
           asp-route-growth="@Model.GrowthFilter"
           aria-current="@(IsActive(DashboardSegments.Completed) ? "page" : null)">
            <div class="dashboard-kpi-card h-100">
                <div class="dashboard-kpi-card__icon dashboard-kpi-card__icon--completed" aria-hidden="true">
                    <i class="bi bi-patch-check-fill"></i>
                </div>
                <div class="dashboard-kpi-card__content">
                    <span class="dashboard-kpi-card__label">Completed</span>
                    <span class="dashboard-kpi-card__value">@($"{Model.Kpi.CompletedCount}/{Model.Kpi.TotalPapsValue}({Model.Kpi.CompletedPercent})")</span>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6 col-xl-3">
        <a class="kpi-link kpi-link--partial h-100 d-block @(IsActive(DashboardSegments.Ongoing) ? "kpi-link--active" : null)"
           asp-controller="@papListController"
           asp-action="@papListAction"
           asp-route-segment="@DashboardSegments.Ongoing"
           asp-route-year="@Model.SelectedYear"
           asp-route-growth="@Model.GrowthFilter"
           aria-current="@(IsActive(DashboardSegments.Ongoing) ? "page" : null)">
            <div class="dashboard-kpi-card h-100">
                <div class="dashboard-kpi-card__icon dashboard-kpi-card__icon--ongoing" aria-hidden="true">
                    <i class="bi bi-arrow-clockwise"></i>
                </div>
                <div class="dashboard-kpi-card__content">
                    <span class="dashboard-kpi-card__label">Ongoing</span>
                    <span class="dashboard-kpi-card__value">@($"{Model.Kpi.OngoingCount}/{Model.Kpi.TotalPapsValue}({Model.Kpi.OngoingPercent})")</span>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6 col-xl-3">
        <a class="kpi-link kpi-link--partial h-100 d-block @(IsActive(DashboardSegments.NotStarted) ? "kpi-link--active" : null)"
           asp-controller="@papListController"
           asp-action="@papListAction"
           asp-route-segment="@DashboardSegments.NotStarted"
           asp-route-year="@Model.SelectedYear"
           asp-route-growth="@Model.GrowthFilter"
           aria-current="@(IsActive(DashboardSegments.NotStarted) ? "page" : null)">
            <div class="dashboard-kpi-card h-100">
                <div class="dashboard-kpi-card__icon dashboard-kpi-card__icon--not-started" aria-hidden="true">
                    <i class="bi bi-dash-circle"></i>
                </div>
                <div class="dashboard-kpi-card__content">
                    <span class="dashboard-kpi-card__label">Not started</span>
                    <span class="dashboard-kpi-card__value">@($"{Model.Kpi.NotStartedCount}/{Model.Kpi.TotalPapsValue}({Model.Kpi.NotStartedPercent})")</span>
                </div>
            </div>
        </a>
    </div>
</div>
}

@if (!string.IsNullOrWhiteSpace(mainHeading))
{
    <header class="dashboard-page-header mb-2 mb-lg-3">
        <h1 class="dashboard-page-title">@mainHeading</h1>
    </header>
}

<div id="papTableCard" class="pap-table-card-wrap"@if (showTableToolbar && !string.IsNullOrWhiteSpace(papSearchListKey)) { <text> data-pap-search-list="@papSearchListKey"</text> }@if (!string.IsNullOrWhiteSpace(completionPhotoUploadUrl)) { <text> data-project-completion-photo-upload-url="@completionPhotoUploadUrl"</text> }>
    <div class="dashboard-card__body p-0">
        @if (showGrowthFilter)
        {
            <form method="get"
                  asp-controller="@papListController"
                  asp-action="@papListAction"
                  asp-route-segment="@Model.Kpi.ActiveSegment"
                  class="dashboard-growth-filter px-3 py-3 border-bottom bg-white">
                <input type="hidden" name="year" value="@Model.SelectedYear" />
                @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
                {
                    <input type="hidden" name="q" value="@Model.SearchQuery" />
                }
                <div class="row g-2 align-items-end align-items-sm-center">
                    <div class="col-12 col-sm-auto">
                        <label for="papGrowthFilter" class="form-label small fw-semibold text-body-secondary mb-1 mb-sm-0">GROWTH</label>
                    </div>
                    <div class="col-12 col-sm-6 col-lg-5 col-xl-4">
                        <select name="growth"
                                id="papGrowthFilter"
                                class="form-select form-select-sm dashboard-growth-filter-select"
                                aria-label="Filter rows by GROWTH alignment">
                            <option value="" selected="@(Model.GrowthFilter == null)">All</option>
                            @foreach (var g in DashboardPapSelectOptions.Growth)
                            {
                                <option value="@g" selected="@(Model.GrowthFilter == g)">@g</option>
                            }
                        </select>
                    </div>
                </div>
            </form>
        }
        @if (showTableToolbar)
        {
            ViewData["ToolbarSearchQuery"] = Model.SearchQuery;
            @await Html.PartialAsync("_UserReportTableToolbar")
        }
        <div class="table-responsive">
            <table id="papDetailTable" class="table table-bordered dashboard-pap-table align-middle mb-0 @(showPriorityNoColumn ? "dashboard-pap-table--priority-col" : null)" data-editing="false" data-report-year="@Model.SelectedYear">
                <thead>
                    <tr>
                        @if (showPriorityNoColumn)
                        {
                            <th scope="col" rowspan="2" class="dashboard-pap-thead">Priority No.</th>
                        }
                        <th scope="col" rowspan="2" class="dashboard-pap-thead">Programs/Activities/Projects (PAPs)</th>
                        <th scope="col" rowspan="2" class="dashboard-pap-thead">Responsible Person</th>
                        <th scope="col" rowspan="2" class="dashboard-pap-thead">Budget Allocation</th>
                        <th scope="colgroup" colspan="2" class="dashboard-pap-thead">Time Frame</th>
                        <th scope="col" rowspan="2" class="dashboard-pap-thead">Support Offices/Units</th>
                        <th scope="colgroup" colspan="2" class="dashboard-pap-thead">Alignment</th>
                        <th scope="col" rowspan="2" class="dashboard-pap-thead">Remarks (Continuing, New, etc.)</th>
                        <th scope="colgroup" colspan="4" class="dashboard-pap-thead">Status</th>
                        @if (showCompletionPhotoColumn)
                        {
                            <th scope="col" rowspan="2" class="dashboard-pap-thead dashboard-pap-thead--completion-photo text-nowrap">Completion photo</th>
                        }
                        <th scope="col" rowspan="2" class="dashboard-pap-thead">Remarks</th>
                        @if (showRowActionsColumn)
                        {
                            <th scope="col" rowspan="2" class="dashboard-pap-thead dashboard-pap-thead--actions">@rowActionsColumnHeading</th>
                        }
                    </tr>
                    <tr>
                        <th scope="col" class="dashboard-pap-thead">Start</th>
                        <th scope="col" class="dashboard-pap-thead">End</th>
                        <th scope="col" class="dashboard-pap-thead">GROWTH</th>
                        <th scope="col" class="dashboard-pap-thead">ACHIEVE</th>
                        <th scope="col" class="dashboard-pap-thead">1st quarter</th>
                        <th scope="col" class="dashboard-pap-thead">2nd quarter</th>
                        <th scope="col" class="dashboard-pap-thead">3rd quarter</th>
                        <th scope="col" class="dashboard-pap-thead">4th quarter</th>
                    </tr>
                </thead>
                <tbody>
                    @await Html.PartialAsync("_DashboardPapTableTbodyRows", Model, ViewData)
                </tbody>
            </table>
        </div>
        <div id="papTablePaginationShell">
            @await Html.PartialAsync("_DashboardPapTablePagination", Model, ViewData)
        </div>
    </div>
</div>
</div>
