<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Dashboard")</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebar.css" asp-append-version="true" />
    @* Prefetch the other dashboard page so the next click often loads from cache (less flicker). *@
    <link rel="prefetch" href="@Url.Action("Dashboard", "Dashboard")" />
    <link rel="prefetch" href="@Url.Action("Reports", "Dashboard")" />
    <link rel="prefetch" href="@Url.Action("OfficeManagement", "OfficeManagement")" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="m-0 app-layout-body overflow-x-hidden">
    @RenderBody()

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
