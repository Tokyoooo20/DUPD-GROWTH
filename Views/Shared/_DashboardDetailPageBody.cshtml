@model DupdGrowth.Web.Models.DashboardDetailViewModel
@{
    ViewData["Title"] = ViewData["Title"] as string ?? "PAP list";
    ViewData["SidebarActive"] = ViewData["SidebarActive"] as string ?? "dashboard";
    ViewData["SidebarUserName"] = ViewData["SidebarUserName"] as string ?? "Sample User";
    ViewData["NavbarShowYear"] = ViewData["NavbarShowYear"] as bool? ?? true;

    var dashboardShellMode = ViewData["DashboardShellMode"] as string ?? "admin";
    var detailBackController = ViewData["DetailBackController"] as string ?? "Dashboard";
    var detailBackAction = ViewData["DetailBackAction"] as string ?? "Dashboard";
    var detailBackIncludeYear = ViewData["DetailBackIncludeYear"] as bool? ?? true;
    var detailBackUrl = detailBackIncludeYear
        ? Url.Action(detailBackAction, detailBackController, new { year = Model.SelectedYear })!
        : Url.Action(detailBackAction, detailBackController)!;

    var showBackLink = ViewData["DashboardDetailShowBackLink"] as bool? ?? true;
    var showTableToolbar = ViewData["DashboardDetailShowTableToolbar"] as bool? ?? false;
    var papSearchListKey = ViewData["PapSearchListKey"] as string;
    var hidePapEditModal = ViewData["DashboardDetailHidePapEditModal"] as bool? ?? false;
    var sidebarPartialName = string.Equals(dashboardShellMode, "user", StringComparison.OrdinalIgnoreCase)
        ? "_SidebarUser"
        : "_Sidebar";
}
<div class="app-shell d-flex">
    <div class="dashboard-sidebar-shell flex-shrink-0" id="dashboardDetailSidebarShell">
        <button type="button"
                id="dashboardSidebarToggle"
                class="dashboard-sidebar-toggle btn btn-sm position-absolute top-0 end-0 mt-2 me-2 z-3 rounded-2"
                aria-expanded="true"
                aria-controls="dashboardDetailSidebarShell"
                title="Collapse sidebar">
            <i class="bi bi-layout-sidebar-inset-reverse dashboard-sidebar-toggle-icon" aria-hidden="true"></i>
            <span class="visually-hidden">Toggle sidebar width</span>
        </button>
        @await Html.PartialAsync(sidebarPartialName)
    </div>
    <div class="app-content d-flex flex-column flex-grow-1 min-w-0">
        @await Html.PartialAsync("Navbar")
        <main role="main"
              class="app-main flex-grow-1 bg-light"
              data-dashboard-detail-ajax="@(ViewData["DashboardDetailAjaxNav"] as bool? == true ? "true" : "false")">
            <div class="container-fluid dashboard-page dashboard-page--tight px-3 px-sm-4 px-lg-5 pb-4 pb-lg-4">
                @if (showBackLink)
                {
                    <header class="dashboard-page-header mb-2 mb-lg-3">
                        <nav aria-label="Back to dashboard">
                            <a class="text-decoration-none dashboard-detail-back" href="@detailBackUrl">
                                <i class="bi bi-arrow-left dashboard-detail-back__icon" aria-hidden="true"></i>
                                <span class="dashboard-detail-back__label">Back to dashboard</span>
                            </a>
                        </nav>
                    </header>
                }

                @await Html.PartialAsync("_DashboardDetailSwappable", Model, ViewData)
                @if (ViewData["DashboardDetailAjaxNav"] as bool? == true)
                {
                    <script src="~/js/dashboard-detail-partial-nav.js" asp-append-version="true"></script>
                }
                @if (showTableToolbar && !string.IsNullOrWhiteSpace(papSearchListKey))
                {
                    <script src="~/js/user-pap-table-search.js" asp-append-version="true"></script>
                }
            </div>
        </main>
    </div>
</div>
@* Outside .app-shell so Bootstrap fixed modal centers on the viewport (overflow on shell was offsetting client Reports). *@
@if (!hidePapEditModal)
{
    ViewData["ModalId"] = "papEditModal";
    ViewData["ModalTitle"] = "Edit row";
    ViewData["ModalSize"] = "modal-xl";
    ViewData["ModalScrollable"] = true;
    ViewData["ModalCentered"] = true;
    ViewData["ModalBody"] = null;
    ViewData["ModalBodyPartial"] = "_PapRowEditModalBody";
    ViewData["ModalPrimaryText"] = "Save";
    ViewData["ModalSecondaryText"] = "Cancel";
    ViewData["ModalPrimaryButtonId"] = "papEditModalSave";
    ViewData["ModalPrimaryDismiss"] = false;
}
@if (!hidePapEditModal)
{
    @await Html.PartialAsync("Modal")
}
