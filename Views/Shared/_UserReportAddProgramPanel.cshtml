@* Centered modal (same field IDs as inline Create New form). *@
<div class="modal fade"
     id="userReportAddProgramPanel"
     tabindex="-1"
     aria-labelledby="userReportAddProgramPanelLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header border-bottom py-3">
                <h5 class="modal-title fw-semibold mb-0" id="userReportAddProgramPanelLabel">Add Program</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body d-flex flex-column gap-3 pt-3 pb-2">
                @await Html.PartialAsync("_UserReportAddProgramFormFields")
            </div>
            <div class="modal-footer border-top flex-wrap gap-2" id="userReportAddProgramFooterAdd">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="userReportAddProgramSave">Save as Endorsed</button>
            </div>
            <div class="modal-footer border-top flex-wrap gap-2 d-none" id="userReportAddProgramFooterEdit">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-outline-primary" id="userReportAddProgramEditDraft">Draft</button>
                <button type="button" class="btn btn-outline-danger" id="userReportAddProgramEditDropped">Dropped</button>
                <button type="button" class="btn btn-outline-primary" id="userReportAddProgramEditEndorsed">Endorsed</button>
            </div>
        </div>
    </div>
</div>
