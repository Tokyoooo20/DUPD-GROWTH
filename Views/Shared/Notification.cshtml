@* Fixed-position host for toast-style alerts. Requires ~/css/notification.css and ~/js/app-notification.js (e.g. from _LayoutDashboard). Call window.showAppNotification(message, 'success' | 'error'). *@
<div id="appNotificationHost"
     class="app-notification-host"
     aria-live="polite"
     aria-relevant="additions"
     aria-atomic="false"></div>
