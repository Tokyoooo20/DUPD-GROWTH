@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Office Management";
    ViewData["SidebarActive"] = "office";
    ViewData["SidebarUserName"] = "Sample User";
}
@section Styles {
    <link rel="stylesheet" href="~/css/SuperAdmin/superadmin-dashboard.css" asp-append-version="true" />
    <style>
        .office-tree-name {
            min-width: 0;
        }

        .office-table-toolbar {
            --office-toolbar-select-min: 14rem;
        }

        .office-table-toolbar #officeTopLevelFilter {
            min-width: min(100%, var(--office-toolbar-select-min));
        }

        .office-table-toolbar__actions {
            flex-shrink: 0;
        }

        .office-table-toolbar__actions .btn {
            min-height: calc(1.5em + 0.75rem + 2px);
            padding-top: 0.375rem;
            padding-bottom: 0.375rem;
        }

        .office-table-toolbar__fields {
            min-width: 0;
        }

        .office-tree-actions .btn {
            white-space: nowrap;
        }
    </style>
}
<div class="app-shell d-flex">
    @await Html.PartialAsync("_Sidebar")
    <div class="app-content d-flex flex-column flex-grow-1 min-w-0">
        @await Html.PartialAsync("Navbar")
        <main role="main" class="app-main flex-grow-1 bg-light">
            <div class="container-fluid dashboard-page dashboard-page--tight px-3 px-sm-4 px-lg-5 pb-4 pb-lg-4">
                <header class="dashboard-page-header mb-2 mb-lg-3">
                    <h1 class="dashboard-page-title">OFFICE MANAGEMENT</h1>
                </header>
                <div class="card dashboard-card border-0 shadow-sm">
                    <div class="dashboard-card__body p-0">
                        <div class="office-table-toolbar border-bottom py-3 px-3 px-md-4 bg-white">
                            <div class="d-flex flex-column flex-xl-row gap-3 align-items-stretch align-xl-end">
                                <div class="office-table-toolbar__fields flex-grow-1 d-flex flex-column flex-lg-row gap-3 gap-lg-4 min-w-0">
                                    <div class="flex-grow-1 min-w-0">
                                        <label class="form-label small text-body-secondary mb-1" for="officeTableSearch">Search offices</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white border-end-0" id="officeSearchAddon"><i class="bi bi-search" aria-hidden="true"></i></span>
                                            <input type="search"
                                                   class="form-control border-start-0"
                                                   id="officeTableSearch"
                                                   placeholder="Search by name"
                                                   autocomplete="off"
                                                   aria-describedby="officeSearchAddon" />
                                        </div>
                                    </div>
                                    <div class="flex-shrink-0" style="width: 100%; max-width: 22rem;">
                                        <label class="form-label small text-body-secondary mb-1" for="officeTopLevelFilter">Top-level office</label>
                                        <select class="form-select" id="officeTopLevelFilter" aria-label="Filter by top-level office">
                                            <option value="">All top-level offices</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="office-table-toolbar__actions d-flex flex-column ms-xl-auto">
                                    <span class="form-label small mb-1 invisible user-select-none" aria-hidden="true">Actions</span>
                                    <div class="d-flex flex-wrap gap-2 justify-content-end">
                                        <button type="button"
                                                class="btn btn-sm btn-outline-secondary"
                                                data-bs-toggle="modal"
                                                data-bs-target="#addYearModal">
                                            Add Year
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th scope="col">Office</th>
                                        <th scope="col" class="text-end office-tree-actions">Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="officeTreeBody">
                                </tbody>
                            </table>
                        </div>
                        <p class="text-body-secondary small px-3 py-2 mb-0 d-none" id="officeTreeEmpty">No offices to display.</p>
                    </div>
                </div>
            </div>
        </main>
        @{
            var addYearModal = new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
            {
                ["ModalId"] = "addYearModal",
                ["ModalTitle"] = "Add year",
                ["ModalBody"] = "<div class=\"mb-0\"><label for=\"addYearInput\" class=\"form-label\">Year</label><input type=\"number\" class=\"form-control\" id=\"addYearInput\" name=\"year\" min=\"2000\" max=\"2100\" placeholder=\"e.g. 2026\" /></div>",
                ["ModalPrimaryText"] = "Save",
                ["ModalSecondaryText"] = "Cancel",
            };
            var addOfficeModalBody =
                "<div class=\"mb-0\">" +
                "<label for=\"addOfficeNameInput\" class=\"form-label\">Office name</label>" +
                "<input type=\"text\" class=\"form-control\" id=\"addOfficeNameInput\" autocomplete=\"off\" maxlength=\"200\" placeholder=\"\" />" +
                "</div>" +
                "<input type=\"hidden\" id=\"officeModalEditId\" value=\"\" />" +
                "<input type=\"hidden\" id=\"officeModalParentId\" value=\"\" />";
            var addOfficeModal = new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
            {
                ["ModalId"] = "addOfficeModal",
                ["ModalTitle"] = "Add office",
                ["ModalBody"] = addOfficeModalBody,
                ["ModalPrimaryText"] = "Save",
                ["ModalSecondaryText"] = "Cancel",
                ["ModalPrimaryButtonId"] = "officeModalSaveBtn",
                ["ModalPrimaryDismiss"] = false,
            };
        }
        @await Html.PartialAsync("Modal", null, addYearModal)
        @await Html.PartialAsync("Modal", null, addOfficeModal)
    </div>
</div>
@section Scripts {
    <script>
        (function () {
            /**
             * Frontend-only office list: { id: number, name: string, parent_id: number | null }
             */
            var offices = [
                { id: 1, name: 'Office of the University President', parent_id: null },
                { id: 2, name: 'Office of the Vice President for Academic Affairs', parent_id: null },
                { id: 3, name: 'Office of the Vice President for Finance and Administration', parent_id: null },
                { id: 4, name: 'Office of the Vice President for Research, Innovation and Extension', parent_id: null },
                { id: 5, name: 'Office of the Vice President for Global Affairs and Strategic Operations', parent_id: null },
                { id: 6, name: 'Office of the Chancellor', parent_id: null }
            ];
            var nextOfficeId = 7;

            var tbody = document.getElementById('officeTreeBody');
            var emptyHint = document.getElementById('officeTreeEmpty');
            var searchInput = document.getElementById('officeTableSearch');
            var topLevelFilter = document.getElementById('officeTopLevelFilter');
            var modalEl = document.getElementById('addOfficeModal');
            var titleEl = document.getElementById('addOfficeModalLabel');
            var nameInput = document.getElementById('addOfficeNameInput');
            var editIdInput = document.getElementById('officeModalEditId');
            var parentIdInput = document.getElementById('officeModalParentId');
            var saveBtn = document.getElementById('officeModalSaveBtn');

            function sortByName(a, b) {
                return a.name.localeCompare(b.name, undefined, { sensitivity: 'base' });
            }

            function getChildren(parentId) {
                return offices.filter(function (o) { return o.parent_id === parentId; }).sort(sortByName);
            }

            function getDescendantIds(officeId) {
                var ids = [];
                getChildren(officeId).forEach(function (child) {
                    ids.push(child.id);
                    ids = ids.concat(getDescendantIds(child.id));
                });
                return ids;
            }

            function getAllowedIdSet(filterRootId) {
                if (filterRootId == null || filterRootId === '') {
                    return null;
                }
                var rid = parseInt(filterRootId, 10);
                if (isNaN(rid)) {
                    return null;
                }
                var set = {};
                set[rid] = true;
                getDescendantIds(rid).forEach(function (id) { set[id] = true; });
                return set;
            }

            function refreshTopLevelDropdown() {
                if (!topLevelFilter) return;
                var prev = topLevelFilter.value;
                topLevelFilter.innerHTML = '';
                var allOpt = document.createElement('option');
                allOpt.value = '';
                allOpt.textContent = 'All top-level offices';
                topLevelFilter.appendChild(allOpt);
                getChildren(null).forEach(function (o) {
                    var opt = document.createElement('option');
                    opt.value = String(o.id);
                    opt.textContent = o.name;
                    topLevelFilter.appendChild(opt);
                });
                if (prev && offices.some(function (o) { return String(o.id) === prev && o.parent_id === null; })) {
                    topLevelFilter.value = prev;
                } else {
                    topLevelFilter.value = '';
                }
            }

            function renderOfficeRows() {
                if (!tbody) return;
                tbody.innerHTML = '';

                var q = (searchInput && searchInput.value || '').trim().toLowerCase();
                var filterRootVal = topLevelFilter ? topLevelFilter.value : '';
                var allowed = getAllowedIdSet(filterRootVal);

                function officeInScope(o) {
                    if (!allowed) {
                        return true;
                    }
                    return !!allowed[o.id];
                }

                function appendRow(o) {
                    var tr = document.createElement('tr');
                    tr.setAttribute('data-office-id', String(o.id));

                    var tdName = document.createElement('td');
                    tdName.className = 'office-tree-name';
                    tdName.textContent = o.name;

                    var tdAct = document.createElement('td');
                    tdAct.className = 'text-end office-tree-actions';

                    var btnSub = document.createElement('button');
                    btnSub.type = 'button';
                    btnSub.className = 'btn btn-sm btn-outline-primary me-1';
                    btnSub.textContent = 'Add Sub-Office';
                    btnSub.setAttribute('data-bs-toggle', 'modal');
                    btnSub.setAttribute('data-bs-target', '#addOfficeModal');
                    btnSub.setAttribute('data-office-mode', 'add');
                    btnSub.setAttribute('data-parent-id', String(o.id));

                    var btnEdit = document.createElement('button');
                    btnEdit.type = 'button';
                    btnEdit.className = 'btn btn-sm btn-outline-secondary me-1';
                    btnEdit.textContent = 'Edit';
                    btnEdit.setAttribute('data-bs-toggle', 'modal');
                    btnEdit.setAttribute('data-bs-target', '#addOfficeModal');
                    btnEdit.setAttribute('data-office-mode', 'edit');
                    btnEdit.setAttribute('data-office-id', String(o.id));

                    var btnDel = document.createElement('button');
                    btnDel.type = 'button';
                    btnDel.className = 'btn btn-sm btn-outline-danger';
                    btnDel.textContent = 'Delete';
                    btnDel.setAttribute('data-office-id', String(o.id));

                    btnDel.addEventListener('click', function () {
                        if (!confirm('Delete “' + o.name + '” and all sub-offices under it?')) return;
                        var remove = [o.id].concat(getDescendantIds(o.id));
                        var removeSet = {};
                        remove.forEach(function (id) { removeSet[id] = true; });
                        offices = offices.filter(function (x) { return !removeSet[x.id]; });
                        renderOfficeRows();
                    });

                    tdAct.appendChild(btnSub);
                    tdAct.appendChild(btnEdit);
                    tdAct.appendChild(btnDel);

                    tr.appendChild(tdName);
                    tr.appendChild(tdAct);
                    tbody.appendChild(tr);
                }

                function walkTree(parentId) {
                    getChildren(parentId).forEach(function (o) {
                        if (!officeInScope(o)) {
                            return;
                        }
                        if (q && o.name.toLowerCase().indexOf(q) < 0) {
                            walkTree(o.id);
                            return;
                        }
                        appendRow(o);
                        walkTree(o.id);
                    });
                }

                if (q) {
                    var matched = offices.filter(function (o) {
                        if (!officeInScope(o)) {
                            return false;
                        }
                        return o.name.toLowerCase().indexOf(q) >= 0;
                    }).sort(sortByName);
                    matched.forEach(appendRow);
                } else if (filterRootVal) {
                    var rootId = parseInt(filterRootVal, 10);
                    var rootOffice = offices.filter(function (x) { return x.id === rootId; })[0];
                    if (rootOffice && officeInScope(rootOffice)) {
                        appendRow(rootOffice);
                        walkTree(rootOffice.id);
                    }
                } else {
                    walkTree(null);
                }

                refreshTopLevelDropdown();

                var rowCount = tbody.querySelectorAll('tr').length;
                if (emptyHint) {
                    if (offices.length === 0) {
                        emptyHint.classList.remove('d-none');
                        emptyHint.innerHTML = 'No offices to display.';
                    } else if (rowCount === 0) {
                        emptyHint.classList.remove('d-none');
                        emptyHint.innerHTML = 'No offices match your search or filter. Try clearing the search or choosing <strong>All top-level offices</strong>.';
                    } else {
                        emptyHint.classList.add('d-none');
                    }
                }
            }

            function openModalSetup(relatedTarget) {
                var mode = relatedTarget && relatedTarget.getAttribute('data-office-mode');
                var editIdAttr = relatedTarget && relatedTarget.getAttribute('data-office-id');
                var parentPreset = relatedTarget && relatedTarget.getAttribute('data-parent-id');

                editIdInput.value = '';
                if (parentIdInput) parentIdInput.value = '';

                if (mode === 'edit' && editIdAttr) {
                    var oid = parseInt(editIdAttr, 10);
                    var office = offices.filter(function (x) { return x.id === oid; })[0];
                    if (!office) return;

                    if (titleEl) titleEl.textContent = 'Edit office';
                    nameInput.value = office.name;
                    editIdInput.value = String(oid);
                    return;
                }

                if (titleEl) titleEl.textContent = 'Add sub-office';
                nameInput.value = '';
                if (parentPreset && parentIdInput) {
                    parentIdInput.value = String(parentPreset);
                }
            }

            if (modalEl) {
                modalEl.addEventListener('show.bs.modal', function (event) {
                    openModalSetup(event.relatedTarget);
                });
            }

            if (searchInput) {
                searchInput.addEventListener('input', function () {
                    renderOfficeRows();
                });
            }

            if (topLevelFilter) {
                topLevelFilter.addEventListener('change', function () {
                    renderOfficeRows();
                });
            }

            if (saveBtn) {
                saveBtn.addEventListener('click', function () {
                    var name = (nameInput.value || '').trim();
                    if (!name) {
                        nameInput.focus();
                        return;
                    }

                    var editId = editIdInput.value ? parseInt(editIdInput.value, 10) : null;

                    if (editId) {
                        var target = offices.filter(function (x) { return x.id === editId; })[0];
                        if (target) {
                            target.name = name;
                        }
                    } else {
                        var pv = parentIdInput ? parentIdInput.value : '';
                        var parent_id = pv === '' || pv == null ? null : parseInt(pv, 10);
                        if (parent_id == null || isNaN(parent_id)) {
                            return;
                        }
                        offices.push({
                            id: nextOfficeId++,
                            name: name,
                            parent_id: parent_id
                        });
                    }

                    renderOfficeRows();

                    var modal = bootstrap.Modal.getInstance(modalEl);
                    if (modal) modal.hide();
                });
            }

            renderOfficeRows();
        })();
    </script>
}
