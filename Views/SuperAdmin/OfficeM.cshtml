@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "Office Management";
    ViewData["SidebarActive"] = "office";
    ViewData["SidebarUserName"] = "Sample User";
}
@section Styles {
    <link rel="stylesheet" href="~/css/SuperAdmin/superadmin-dashboard.css" asp-append-version="true" />
    <style>
        .office-tree-name {
            min-width: 0;
        }

        .office-table-toolbar {
            --office-toolbar-select-min: 14rem;
        }

        .office-table-toolbar #officeTopLevelFilter {
            min-width: min(100%, var(--office-toolbar-select-min));
        }

        .office-table-toolbar__fields {
            min-width: 0;
        }

        .office-tree-actions .btn {
            white-space: nowrap;
        }
    </style>
}
<div class="app-shell d-flex">
    @await Html.PartialAsync("_Sidebar")
    <div class="app-content d-flex flex-column flex-grow-1 min-w-0">
        @await Html.PartialAsync("Navbar")
        <main role="main" class="app-main flex-grow-1 bg-light">
            <div class="container-fluid dashboard-page dashboard-page--tight px-3 px-sm-4 px-lg-5 pb-4 pb-lg-4">
                <header class="dashboard-page-header mb-2 mb-lg-3">
                    <h1 class="dashboard-page-title">OFFICE MANAGEMENT</h1>
                </header>
                <div class="d-none" aria-hidden="true">
                    @Html.AntiForgeryToken()
                </div>
                <div class="card dashboard-card border-0 shadow-sm">
                    <div class="dashboard-card__body p-0">
                        <div class="office-table-toolbar border-bottom py-3 px-3 px-md-4 bg-white">
                            <div class="office-table-toolbar__fields d-flex flex-column flex-lg-row gap-3 gap-lg-4 min-w-0">
                                <div class="flex-grow-1 min-w-0">
                                    <label class="form-label small text-body-secondary mb-1" for="officeTableSearch">Search offices</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-end-0" id="officeSearchAddon"><i class="bi bi-search" aria-hidden="true"></i></span>
                                        <input type="search"
                                               class="form-control border-start-0"
                                               id="officeTableSearch"
                                               placeholder="Search by name"
                                               autocomplete="off"
                                               aria-describedby="officeSearchAddon" />
                                    </div>
                                </div>
                                <div class="flex-shrink-0" style="width: 100%; max-width: 22rem;">
                                    <label class="form-label small text-body-secondary mb-1" for="officeTopLevelFilter">Offices</label>
                                    <select class="form-select" id="officeTopLevelFilter" aria-label="Filter by office">
                                        <option value="">Top level offices</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th scope="col">Office</th>
                                        <th scope="col" class="text-end office-tree-actions">Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="officeTreeBody">
                                </tbody>
                            </table>
                        </div>
                        <p class="text-body-secondary small px-3 py-2 mb-0 d-none" id="officeTreeEmpty">No offices to display.</p>
                    </div>
                </div>
            </div>
        </main>
        @{
            var addOfficeModalBody =
                "<div class=\"mb-0\">" +
                "<label for=\"addOfficeNameInput\" class=\"form-label\">Office name</label>" +
                "<input type=\"text\" class=\"form-control\" id=\"addOfficeNameInput\" autocomplete=\"off\" maxlength=\"200\" placeholder=\"\" />" +
                "</div>" +
                "<input type=\"hidden\" id=\"officeModalEditId\" value=\"\" />" +
                "<input type=\"hidden\" id=\"officeModalParentId\" value=\"\" />";
            var addOfficeModal = new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
            {
                ["ModalId"] = "addOfficeModal",
                ["ModalTitle"] = "Add office",
                ["ModalBody"] = addOfficeModalBody,
                ["ModalPrimaryText"] = "Save",
                ["ModalSecondaryText"] = "Cancel",
                ["ModalPrimaryButtonId"] = "officeModalSaveBtn",
                ["ModalPrimaryDismiss"] = false,
            };
            var confirmDeleteOfficeModalBody =
                "<p class=\"mb-0\" id=\"officeDeleteConfirmMessage\"></p>";
            var confirmDeleteOfficeModal = new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
            {
                ["ModalId"] = "confirmDeleteOfficeModal",
                ["ModalTitle"] = "Delete office?",
                ["ModalBody"] = confirmDeleteOfficeModalBody,
                ["ModalPrimaryText"] = "Delete",
                ["ModalSecondaryText"] = "Cancel",
                ["ModalPrimaryButtonId"] = "officeDeleteConfirmBtn",
                ["ModalPrimaryButtonClass"] = "btn btn-danger",
                ["ModalPrimaryDismiss"] = false,
            };
            var confirmSaveOfficeModalBody =
                "<p class=\"mb-0\" id=\"officeSaveConfirmMessage\"></p>";
            var confirmSaveOfficeModal = new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
            {
                ["ModalId"] = "confirmSaveOfficeModal",
                ["ModalTitle"] = "Save office?",
                ["ModalBody"] = confirmSaveOfficeModalBody,
                ["ModalPrimaryText"] = "Yes, save",
                ["ModalSecondaryText"] = "Cancel",
                ["ModalPrimaryButtonId"] = "officeSaveConfirmBtn",
                ["ModalPrimaryDismiss"] = false,
            };
        }
        @await Html.PartialAsync("Modal", null, addOfficeModal)
        @await Html.PartialAsync("Modal", null, confirmDeleteOfficeModal)
        @await Html.PartialAsync("Modal", null, confirmSaveOfficeModal)
    </div>
</div>
@section Scripts {
    <script type="application/json" id="offices-data-json">@Html.Raw(ViewData["OfficesJson"] ?? "[]")</script>
    @{
        var officeApiUrls = new
        {
            createSubOffice = Url.Action("CreateSubOffice", "OfficeManagement"),
            updateOffice = Url.Action("UpdateOffice", "OfficeManagement"),
            deleteOffice = Url.Action("DeleteOffice", "OfficeManagement"),
        };
    }
    <script>
        window.officeManagementApi = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(officeApiUrls));
    </script>
    <script>
        (function () {
            /**
             * All office rows from `offices` (single JSON). Top-level filter = only `parent_id === null` (SQL NULL).
             */
            var officesDataEl = document.getElementById('offices-data-json');
            var offices = [];
            function normalizeOfficeRow(raw) {
                var pid = raw.parent_id;
                if (pid === undefined && raw.parentId !== undefined) {
                    pid = raw.parentId;
                }
                return { id: raw.id, name: raw.name != null ? String(raw.name) : '', parent_id: pid };
            }

            if (officesDataEl && officesDataEl.textContent) {
                try {
                    offices = JSON.parse(officesDataEl.textContent);
                } catch (e) {
                    offices = [];
                }
            }
            if (!Array.isArray(offices)) {
                offices = [];
            }
            offices = offices.map(normalizeOfficeRow);

            var nextOfficeId = offices.reduce(function (max, o) {
                var n = parseInt(String(o.id), 10);
                return isNaN(n) ? max : Math.max(max, n);
            }, 0) + 1;

            var tbody = document.getElementById('officeTreeBody');
            var emptyHint = document.getElementById('officeTreeEmpty');
            var searchInput = document.getElementById('officeTableSearch');
            var topLevelFilter = document.getElementById('officeTopLevelFilter');
            var modalEl = document.getElementById('addOfficeModal');
            var titleEl = document.getElementById('addOfficeModalLabel');
            var nameInput = document.getElementById('addOfficeNameInput');
            var editIdInput = document.getElementById('officeModalEditId');
            var parentIdInput = document.getElementById('officeModalParentId');
            var saveBtn = document.getElementById('officeModalSaveBtn');
            var confirmDeleteModalEl = document.getElementById('confirmDeleteOfficeModal');
            var officeDeleteConfirmMessageEl = document.getElementById('officeDeleteConfirmMessage');
            var officeDeleteConfirmBtn = document.getElementById('officeDeleteConfirmBtn');
            var pendingDeleteOffice = null;
            var confirmSaveModalEl = document.getElementById('confirmSaveOfficeModal');
            var officeSaveConfirmMessageEl = document.getElementById('officeSaveConfirmMessage');
            var officeSaveConfirmBtn = document.getElementById('officeSaveConfirmBtn');
            var saveConfirmCommitted = false;

            function notifySuccess(message) {
                if (typeof window.showAppNotification === 'function') {
                    window.showAppNotification(message, 'success');
                }
            }

            function notifyError(message) {
                if (typeof window.showAppNotification === 'function') {
                    window.showAppNotification(message, 'error');
                }
            }

            function sortByName(a, b) {
                return a.name.localeCompare(b.name, undefined, { sensitivity: 'base' });
            }

            /** Matches DB: `offices.parent_id` IS NULL (JSON null) only — not 0, not "", not undefined. */
            function isRootOfficeRow(o) {
                return o != null && o.parent_id === null;
            }

            /** Top Level Offices dropdown: same list as true parent rows from the main payload (no second source). */
            function getDropdownTopLevelOptions() {
                return offices.filter(isRootOfficeRow).sort(sortByName);
            }

            function getChildren(parentId) {
                return offices.filter(function (o) {
                    if (parentId == null || parentId === undefined) {
                        return isRootOfficeRow(o);
                    }
                    if (isRootOfficeRow(o)) {
                        return false;
                    }
                    return Number(o.parent_id) === Number(parentId);
                }).sort(sortByName);
            }

            function getDescendantIds(officeId) {
                var ids = [];
                getChildren(officeId).forEach(function (child) {
                    ids.push(child.id);
                    ids = ids.concat(getDescendantIds(child.id));
                });
                return ids;
            }

            function getAllowedIdSet(filterRootId) {
                if (filterRootId == null || filterRootId === '') {
                    return null;
                }
                var rid = parseInt(filterRootId, 10);
                if (isNaN(rid)) {
                    return null;
                }
                var set = {};
                set[Number(rid)] = true;
                getDescendantIds(rid).forEach(function (id) { set[Number(id)] = true; });
                return set;
            }

            function refreshTopLevelDropdown() {
                if (!topLevelFilter) return;
                var prev = topLevelFilter.value;
                topLevelFilter.innerHTML = '';
                var allOpt = document.createElement('option');
                allOpt.value = '';
                allOpt.textContent = 'Top level offices';
                topLevelFilter.appendChild(allOpt);
                getDropdownTopLevelOptions().forEach(function (o) {
                    var opt = document.createElement('option');
                    opt.value = String(o.id);
                    opt.textContent = o.name;
                    topLevelFilter.appendChild(opt);
                });
                if (prev && getDropdownTopLevelOptions().some(function (o) { return String(o.id) === prev; })) {
                    topLevelFilter.value = prev;
                } else {
                    topLevelFilter.value = '';
                }
            }

            function renderOfficeRows() {
                if (!tbody) return;
                tbody.innerHTML = '';

                var q = (searchInput && searchInput.value || '').trim().toLowerCase();
                var filterRootVal = topLevelFilter ? topLevelFilter.value : '';
                if (filterRootVal) {
                    var checkId = parseInt(filterRootVal, 10);
                    var picked = offices.filter(function (x) { return Number(x.id) === checkId; })[0];
                    if (!picked || !isRootOfficeRow(picked)) {
                        filterRootVal = '';
                        if (topLevelFilter) {
                            topLevelFilter.value = '';
                        }
                    }
                }
                var allowed = getAllowedIdSet(filterRootVal);

                function officeInScope(o) {
                    if (!allowed) {
                        return true;
                    }
                    return !!allowed[Number(o.id)];
                }

                function appendRow(o) {
                    var tr = document.createElement('tr');
                    tr.setAttribute('data-office-id', String(o.id));

                    var tdName = document.createElement('td');
                    tdName.className = 'office-tree-name';
                    tdName.textContent = o.name;

                    var tdAct = document.createElement('td');
                    tdAct.className = 'text-end office-tree-actions';

                    var btnSub = document.createElement('button');
                    btnSub.type = 'button';
                    btnSub.className = 'btn btn-sm btn-outline-primary me-1';
                    btnSub.textContent = 'Add Sub-Office';
                    btnSub.setAttribute('data-bs-toggle', 'modal');
                    btnSub.setAttribute('data-bs-target', '#addOfficeModal');
                    btnSub.setAttribute('data-office-mode', 'add');
                    btnSub.setAttribute('data-parent-id', String(o.id));

                    var btnEdit = document.createElement('button');
                    btnEdit.type = 'button';
                    btnEdit.className = 'btn btn-sm btn-outline-secondary me-1';
                    btnEdit.textContent = 'Edit';
                    btnEdit.setAttribute('data-bs-toggle', 'modal');
                    btnEdit.setAttribute('data-bs-target', '#addOfficeModal');
                    btnEdit.setAttribute('data-office-mode', 'edit');
                    btnEdit.setAttribute('data-office-id', String(o.id));

                    var btnDel = document.createElement('button');
                    btnDel.type = 'button';
                    btnDel.className = 'btn btn-sm btn-outline-danger';
                    btnDel.textContent = 'Delete';
                    btnDel.setAttribute('data-office-id', String(o.id));

                    btnDel.addEventListener('click', function () {
                        pendingDeleteOffice = o;
                        if (officeDeleteConfirmMessageEl) {
                            var subCount = getDescendantIds(o.id).length;
                            var subPhrase = subCount ? ' This will also remove ' + subCount + ' sub-office' + (subCount === 1 ? '' : 's') + ' under it.' : '';
                            officeDeleteConfirmMessageEl.textContent =
                                'Are you sure you want to delete “' + o.name + '”?' + subPhrase + ' This cannot be undone.';
                        }
                        if (confirmDeleteModalEl && typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                            var delModal = bootstrap.Modal.getOrCreateInstance(confirmDeleteModalEl);
                            delModal.show();
                        } else {
                            notifyError('Confirmation dialog could not be opened.');
                            pendingDeleteOffice = null;
                        }
                    });

                    tdAct.appendChild(btnSub);
                    tdAct.appendChild(btnEdit);
                    tdAct.appendChild(btnDel);

                    tr.appendChild(tdName);
                    tr.appendChild(tdAct);
                    tbody.appendChild(tr);
                }

                function walkTree(parentId) {
                    getChildren(parentId).forEach(function (o) {
                        if (!officeInScope(o)) {
                            return;
                        }
                        if (q && o.name.toLowerCase().indexOf(q) < 0) {
                            walkTree(o.id);
                            return;
                        }
                        appendRow(o);
                        walkTree(o.id);
                    });
                }

                if (filterRootVal) {
                    if (q) {
                        var matchedBranch = offices.filter(function (o) {
                            if (!officeInScope(o)) {
                                return false;
                            }
                            return o.name.toLowerCase().indexOf(q) >= 0;
                        }).sort(sortByName);
                        matchedBranch.forEach(appendRow);
                    } else {
                        var rootId = parseInt(filterRootVal, 10);
                        var rootOffice = offices.filter(function (x) { return Number(x.id) === rootId; })[0];
                        if (rootOffice && officeInScope(rootOffice)) {
                            appendRow(rootOffice);
                            walkTree(Number(rootOffice.id));
                        }
                    }
                } else {
                    /* "Top level offices" — only rows with parent_id NULL (no children in this view). */
                    var rootsOnly = getDropdownTopLevelOptions();
                    if (q) {
                        rootsOnly = rootsOnly.filter(function (o) {
                            return o.name.toLowerCase().indexOf(q) >= 0;
                        });
                    }
                    rootsOnly.forEach(appendRow);
                }

                refreshTopLevelDropdown();

                var rowCount = tbody.querySelectorAll('tr').length;
                if (emptyHint) {
                    if (offices.length === 0) {
                        emptyHint.classList.remove('d-none');
                        emptyHint.innerHTML = 'No offices to display.';
                    } else if (rowCount === 0) {
                        emptyHint.classList.remove('d-none');
                        emptyHint.innerHTML = 'No offices match your search or filter. Try clearing the search or choosing <strong>Top level offices</strong>.';
                    } else {
                        emptyHint.classList.add('d-none');
                    }
                }
            }

            function openModalSetup(relatedTarget) {
                var mode = relatedTarget && relatedTarget.getAttribute('data-office-mode');
                var editIdAttr = relatedTarget && relatedTarget.getAttribute('data-office-id');
                var parentPreset = relatedTarget && relatedTarget.getAttribute('data-parent-id');

                editIdInput.value = '';
                if (parentIdInput) parentIdInput.value = '';

                if (mode === 'edit' && editIdAttr) {
                    var oid = parseInt(editIdAttr, 10);
                    var office = offices.filter(function (x) { return x.id === oid; })[0];
                    if (!office) return;

                    if (titleEl) titleEl.textContent = 'Edit office';
                    nameInput.value = office.name;
                    editIdInput.value = String(oid);
                    return;
                }

                if (titleEl) titleEl.textContent = 'Add sub-office';
                nameInput.value = '';
                if (parentPreset && parentIdInput) {
                    parentIdInput.value = String(parentPreset);
                }
            }

            if (modalEl) {
                modalEl.addEventListener('show.bs.modal', function (event) {
                    /* Only reset fields when opened from a table button — not when restoring after confirm cancel. */
                    if (event.relatedTarget) {
                        openModalSetup(event.relatedTarget);
                    }
                });
            }

            if (searchInput) {
                searchInput.addEventListener('input', function () {
                    renderOfficeRows();
                });
            }

            if (topLevelFilter) {
                topLevelFilter.addEventListener('change', function () {
                    renderOfficeRows();
                });
            }

            function getCsrfToken() {
                var el = document.querySelector('input[name="__RequestVerificationToken"]');
                return el ? el.value : '';
            }

            function refreshNextOfficeIdFromOffices() {
                nextOfficeId = offices.reduce(function (max, o) {
                    var n = parseInt(String(o.id), 10);
                    return isNaN(n) ? max : Math.max(max, n);
                }, 0) + 1;
            }

            async function parseJsonResponse(res) {
                var text = await res.text();
                if (!text) return {};
                try {
                    return JSON.parse(text);
                } catch (e) {
                    return {};
                }
            }

            async function performOfficeSaveFromForm() {
                var api = window.officeManagementApi;
                if (!api || !api.createSubOffice || !api.updateOffice) {
                    notifyError('Office save is not configured.');
                    return false;
                }

                var token = getCsrfToken();
                if (!token) {
                    notifyError('Security token missing. Refresh the page and try again.');
                    return false;
                }

                var name = (nameInput.value || '').trim();
                if (!name) {
                    notifyError('Please enter an office name.');
                    nameInput.focus();
                    return false;
                }

                var editId = editIdInput.value ? parseInt(editIdInput.value, 10) : null;

                if (editId) {
                    try {
                        var res = await fetch(api.updateOffice, {
                            method: 'POST',
                            credentials: 'same-origin',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': token
                            },
                            body: JSON.stringify({ id: editId, officeName: name })
                        });
                        var data = await parseJsonResponse(res);
                        if (!res.ok) {
                            var errs = data.errors;
                            var msg = Array.isArray(errs) && errs.length ? errs.join(' ') : (data.message || 'Could not update office.');
                            notifyError(msg);
                            return false;
                        }
                        var target = offices.filter(function (x) { return Number(x.id) === editId; })[0];
                        if (target && data.office) {
                            target.name = data.office.name;
                        }
                        notifySuccess(data.message || 'Office updated successfully.');
                        renderOfficeRows();
                        return true;
                    } catch (e) {
                        notifyError('Could not reach the server. Check your connection and try again.');
                        return false;
                    }
                }

                var pv = parentIdInput ? parentIdInput.value : '';
                var parent_id = pv === '' || pv == null ? null : parseInt(pv, 10);
                if (parent_id == null || isNaN(parent_id)) {
                    notifyError('A parent office is required to add a sub-office.');
                    return false;
                }

                try {
                    var res2 = await fetch(api.createSubOffice, {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify({ officeName: name, parentOfficeId: parent_id })
                    });
                    var data2 = await parseJsonResponse(res2);
                    if (!res2.ok) {
                        var errs2 = data2.errors;
                        var msg2 = Array.isArray(errs2) && errs2.length ? errs2.join(' ') : (data2.message || 'Could not create sub-office.');
                        notifyError(msg2);
                        return false;
                    }
                    if (data2.office) {
                        offices.push(normalizeOfficeRow(data2.office));
                        refreshNextOfficeIdFromOffices();
                    }
                    notifySuccess(data2.message || 'Sub-office added successfully.');
                    renderOfficeRows();
                    return true;
                } catch (e) {
                    notifyError('Could not reach the server. Check your connection and try again.');
                    return false;
                }
            }

            if (saveBtn) {
                saveBtn.addEventListener('click', function () {
                    var name = (nameInput.value || '').trim();
                    if (!name) {
                        notifyError('Please enter an office name.');
                        nameInput.focus();
                        return;
                    }

                    var editId = editIdInput.value ? parseInt(editIdInput.value, 10) : null;

                    if (!editId) {
                        var pv = parentIdInput ? parentIdInput.value : '';
                        var parent_id = pv === '' || pv == null ? null : parseInt(pv, 10);
                        if (parent_id == null || isNaN(parent_id)) {
                            notifyError('A parent office is required to add a sub-office.');
                            return;
                        }
                    }

                    if (officeSaveConfirmMessageEl) {
                        if (editId) {
                            var existing = offices.filter(function (x) { return x.id === editId; })[0];
                            var prevName = existing ? existing.name : '';
                            officeSaveConfirmMessageEl.textContent =
                                'Are you sure you want to save changes to this office? The name will be updated from “' +
                                prevName + '” to “' + name + '”.';
                        } else {
                            var pv2 = parentIdInput ? parentIdInput.value : '';
                            var pid = parseInt(pv2, 10);
                            var parentOffice = offices.filter(function (x) { return Number(x.id) === pid; })[0];
                            var parentLabel = parentOffice ? parentOffice.name : 'the selected parent';
                            officeSaveConfirmMessageEl.textContent =
                                'Are you sure you want to add the sub-office “' + name + '” under “' + parentLabel + '”?';
                        }
                    }

                    if (!confirmSaveModalEl || typeof bootstrap === 'undefined' || !bootstrap.Modal) {
                        notifyError('Confirmation dialog could not be opened.');
                        return;
                    }

                    saveConfirmCommitted = false;
                    var addModal = bootstrap.Modal.getInstance(modalEl) || bootstrap.Modal.getOrCreateInstance(modalEl);
                    var sm = bootstrap.Modal.getOrCreateInstance(confirmSaveModalEl);

                    var onAddHidden = function () {
                        modalEl.removeEventListener('hidden.bs.modal', onAddHidden);
                        sm.show();
                    };
                    modalEl.addEventListener('hidden.bs.modal', onAddHidden);
                    addModal.hide();
                });
            }

            if (officeSaveConfirmBtn && confirmSaveModalEl) {
                officeSaveConfirmBtn.addEventListener('click', async function () {
                    var ok = await performOfficeSaveFromForm();
                    if (ok) {
                        saveConfirmCommitted = true;
                    }
                    var sm = bootstrap.Modal.getInstance(confirmSaveModalEl);
                    if (sm) sm.hide();
                });

                confirmSaveModalEl.addEventListener('hidden.bs.modal', function () {
                    if (!saveConfirmCommitted && modalEl) {
                        var addModal = bootstrap.Modal.getInstance(modalEl) || bootstrap.Modal.getOrCreateInstance(modalEl);
                        addModal.show();
                    }
                    saveConfirmCommitted = false;
                });
            }

            if (officeDeleteConfirmBtn && confirmDeleteModalEl) {
                officeDeleteConfirmBtn.addEventListener('click', async function () {
                    if (!pendingDeleteOffice) {
                        var dm = bootstrap.Modal.getInstance(confirmDeleteModalEl);
                        if (dm) dm.hide();
                        return;
                    }
                    var o = pendingDeleteOffice;
                    var label = o.name;
                    var api = window.officeManagementApi;
                    var token = getCsrfToken();

                    if (!api || !api.deleteOffice) {
                        notifyError('Office delete is not configured.');
                        pendingDeleteOffice = null;
                        var dm0 = bootstrap.Modal.getInstance(confirmDeleteModalEl);
                        if (dm0) dm0.hide();
                        return;
                    }
                    if (!token) {
                        notifyError('Security token missing. Refresh the page and try again.');
                        pendingDeleteOffice = null;
                        var dm1 = bootstrap.Modal.getInstance(confirmDeleteModalEl);
                        if (dm1) dm1.hide();
                        return;
                    }

                    try {
                        var res = await fetch(api.deleteOffice, {
                            method: 'POST',
                            credentials: 'same-origin',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': token
                            },
                            body: JSON.stringify({ id: Number(o.id) })
                        });
                        var data = await parseJsonResponse(res);
                        if (!res.ok) {
                            var errs = data.errors;
                            var msg = Array.isArray(errs) && errs.length ? errs.join(' ') : (data.message || 'Could not delete office.');
                            notifyError(msg);
                        } else {
                            var remove = [o.id].concat(getDescendantIds(o.id));
                            var removeSet = {};
                            remove.forEach(function (id) { removeSet[id] = true; });
                            offices = offices.filter(function (x) { return !removeSet[x.id]; });
                            refreshNextOfficeIdFromOffices();
                            renderOfficeRows();
                            notifySuccess(data.message || '“' + label + '” was removed.');
                        }
                    } catch (err) {
                        notifyError('Could not reach the server. Check your connection and try again.');
                    }

                    pendingDeleteOffice = null;
                    var delModal = bootstrap.Modal.getInstance(confirmDeleteModalEl);
                    if (delModal) delModal.hide();
                });
                confirmDeleteModalEl.addEventListener('hidden.bs.modal', function () {
                    pendingDeleteOffice = null;
                });
            }

            renderOfficeRows();
        })();
    </script>
}
