@model DupdGrowth.Web.Models.LoginViewModel
@{
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                @if (TempData["SignupSuccess"] is string signupMsg)
                {
                    <div class="alert alert-info small py-2" role="status">@signupMsg</div>
                }
                <form method="post" asp-controller="Login" asp-action="Login">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="Email"></label>
                        <input class="form-control" asp-for="Email" autocomplete="username" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="Password"></label>
                        <input class="form-control" asp-for="Password" autocomplete="current-password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Log in</button>
                </form>
                <p class="small text-muted mt-3 mb-0">
                    No account?
                    <a asp-controller="Signup" asp-action="Signup">Sign up</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
